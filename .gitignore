.venv/
__pycache__/
*.pyc
*.pyo
.DS_Store
.env
*.egg-info/
dist/
build/
.ipynb_checkpoints/

# Raw inputs are large (11 GB) and re-downloadable — don't commit.
data/raw/

# NetCDF + HDF5 binary blobs anywhere — large, not text-diffable.
*.nc
*.h5

# Default-ignore CSV/Parquet anywhere, but un-ignore inside data/processed/.
*.csv
*.parquet

# Whitelist the processed pipeline outputs (~126 MB total, largest file 35 MB).
!data/processed/
!data/processed/**

# Local deliverables — not tracked.
paper/
figures/03_build_paper_docx.py
figures/07_build_results_plain_docx.py
figures/08_build_appendix_docx.py
figures/09_build_references_docx.py
